{
  "name": "Image Background - Generate Back View",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "imagebg-back",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-back",
      "name": "Webhook Back",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [500, 300],
      "webhookId": "imagebg-back-prod"
    },
    {
      "parameters": {
        "resource": "image",
        "operation": "edit",
        "prompt": "Back view catalog shot showing garment fit and seams. Neutral studio background, torso-to-full body framing. No identifiable face.",
        "images": {
          "values": [
            {
              "binaryPropertyName": "edited"
            }
          ]
        },
        "options": {
          "binaryPropertyOutput": "back"
        }
      },
      "id": "gemini-back",
      "name": "Gemini Back View",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1,
      "position": [700, 300],
      "credentials": {
        "googlePalmApi": {
          "id": "HdBNLwIq64OFkbh5",
          "name": "Google Gemini(PaLM) Api account 2"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "binary",
        "options": {
          "responseCode": 200,
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "={{$binary.back.mimeType || 'image/png'}}"
              },
              {
                "name": "Content-Disposition",
                "value": "inline; filename=\"back.png\""
              },
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              },
              {
                "name": "Access-Control-Allow-Methods",
                "value": "POST, OPTIONS"
              },
              {
                "name": "Access-Control-Allow-Headers",
                "value": "Content-Type"
              }
            ]
          }
        }
      },
      "id": "response-back",
      "name": "Respond Back",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.4,
      "position": [900, 300]
    }
  ],
  "connections": {
    "Webhook Back": {
      "main": [
        [
          {
            "node": "Gemini Back View",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gemini Back View": {
      "main": [
        [
          {
            "node": "Respond Back",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
  "settings": {
    "executionOrder": "v1"
  }
}


